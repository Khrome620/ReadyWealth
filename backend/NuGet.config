<?xml version="1.0" encoding="utf-8"?>
<!-- Scopes this project to nuget.org only, bypassing any corporate feeds in the user-level NuGet.Config -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
